/**
 * This function applies a data action from the app on a selection of rows entered as a parameter 
 * from AppSheet
 * Documentation source:  https://support.google.com/appsheet/answer/10104497?hl=en&ref_topic=10105767&sjid=1018665257488875345-EU
 * 
 * Params:
 * @APP_ID: appId of app to trigger
 * @APP_ACCESS_KEY: to get in the app editor (make sure integration is enabled)
 * @table: table name to which the action is attached
 * @action:name of the action of type "Data:set the values of some columns in this row"
 * @a_rows: list of rows as an object, for example: "[{idTable:id1},{idTable:id2},{idTable:id3}]"
 * @referencedTableIdColumnName: name of the key-column of the referenced table
 * 
 */
function appsheetAPI_action(APP_ID, APP_ACCESS_KEY, APPSHEET_REGION, table, custom_action, a_rows) {
  let functionName = "appsheetAPI_action"
  Logger.log("Starting " + functionName + " ...")

  let url = "https://" + APPSHEET_REGION + "/api/v2/apps/" + APP_ID + "/tables/" + table + "/Action?applicationAccessKey=" + APP_ACCESS_KEY
  //Logger.log ("url: "+ url)    
  //Logger.log("a_rows: " + JSON.stringify(a_rows, null, 2))

  try {
    let payload = {
      "Action": custom_action,
      "Properties": { "Locale": "en-US" },
      "Rows": a_rows
    }
    //Logger.log ("payload: "+ payload)
    const options = {
      'method': 'post',
      'contentType': 'application/json',
      'muteHttpExceptions': true,
      'payload': JSON.stringify(payload)
    }
    //Logger.log ("options: "+ JSON.stringify(options,null,2))
    let response = UrlFetchApp.fetch(url, options);
    Logger.log("status: " + response.getResponseCode())
    if (response.getResponseCode() != "200") { displayResponseCodeList() }
  } catch (e) {//try {
    handleError_appsheetAPI(e, functionName)
  }//} catch (e) {
}//function appsheetAPI_action(APP_ID, APP_ACCESS_KEY, APPSHEET_REGION, table, custom_action, a_rows) {


