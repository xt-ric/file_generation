/**
 * This function returns a list of records from a table according to a filter expression
 * Documentation source: https://support.google.com/appsheet/answer/10105770?hl=en&ref_topic=10105767&sjid=1018665257488875345-EU
 * 
 * Params:
 * @appID: appId of app to trigger
 * @accessKeyApp: to get in the app editor (make sure integration is enabled)
 * @tableName: table name to which the action is attached
 * @text_selector: filter/select expression given as a text. 
 * @response: the output response is the list of rows in HTTP contents
 * 
 * exemple: 
 * text_selector="FILTER(Items,[current_stock]<40 )"
 * 
 */


function appsheetAPI_find(APP_ID, APP_ACCESS_KEY, APPSHEET_REGION, table, text_selector) {
  let functionName = "appsheetAPI_find"
  Logger.log("Starting " + functionName + " ...")
  let url = "https://" + APPSHEET_REGION + "/api/v2/apps/" + APP_ID + "/tables/" + table + "/Action?applicationAccessKey=" + APP_ACCESS_KEY
  //Logger.log ("url: "+ url)    

  try {
    let payload = {
      "Action": "Find",
      "Properties": {
        "Locale": "en-US",
        "Selector": text_selector,
        "RunAsUserEmail": Session.getEffectiveUser().getEmail()
      },
      "Rows": [
      ]
    }
    //Logger.log ("payload: "+ JSON.stringify(payload,null,2))
    const options = {
      'method': 'post',
      'contentType': 'application/json',
      'muteHttpExceptions': true,
      'payload': JSON.stringify(payload)
    }
    //Logger.log ("options: "+ JSON.stringify(options,null,2))
    let response = UrlFetchApp.fetch(url, options);
    Logger.log("status: " + response.getResponseCode())
    if (response.getResponseCode() != "200") { displayResponseCodeList() }    
    let response_json = JSON.parse(response)
    return response_json
  } catch (e) {//try{
    handleError_appsheetAPI(e, functionName)
  }//} catch (e) {
    
}//function appsheetAPI_find() {


